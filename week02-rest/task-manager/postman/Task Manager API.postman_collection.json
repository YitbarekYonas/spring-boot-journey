        {
          "name": "{{baseUrl}}/api/tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Status check",
                  "pm.test(\"Status 201 Created\", function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "// 2. Location header check",
                  "pm.test(\"Location header present\", function() {",
                  "    pm.response.to.have.header(\"Location\");",
                  "});",
                  "",
                  "// 3. Response has ID",
                  "pm.test(\"Created task has ID\", function() {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task).to.have.property(\"id\");",
                  "    pm.expect(task.id).to.be.a(\"number\");",
                  "});",
                  "",
                  "// 4. SAVE taskId for chaining",
                  "pm.test(\"Save taskId for chaining\", function() {",
                  "    const task = pm.response.json();",
                  "    pm.environment.set(\"taskId\", task.id);",
                  "});",
                  "",
                  "// 5. Check default status is TODO",
                  "pm.test(\"Default status is TODO\", function() {",
                  "    const task = pm.response.json();",
                  "    pm.expect(task.status).to.equal(\"TODO\");",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
