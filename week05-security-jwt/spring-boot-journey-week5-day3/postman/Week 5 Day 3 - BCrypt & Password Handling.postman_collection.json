    {
      "name": "3. Password Change",
      "item": [
        {
          "name": "{{baseUrl}}{{apiVersion}}/auth/change-password",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "password",
                  "value": "{{memberPassword}}",
                  "type": "string"
                },
                {
                  "key": "username",
                  "value": "{{memberEmail}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"currentPassword\": \"{{memberPassword}}\",\n    \"newPassword\": \"{{newUser}}\",\n    \"confirmNewPassword\": \"{{newUser}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
